# Build-time configuration for the frontend.
# Copy to `.env` (or set these in the CodeBuild environment) before `pnpm build`.

# Base URL of the deployed Serverless httpApi, e.g.
# https://abc123.execute-api.ap-southeast-2.amazonaws.com
# Printed in the `serverless deploy` stack outputs (the HttpApiUrl).
PUBLIC_API_BASE_URL=

# Public site URL, used for canonical/sitemap metadata.
SITE_URL=https://603.nz
